% Baseball
%-------------------------------------------------------------------------------
\newcommand{\psSportBaseBall}[1][]{\setkeys{\kvf}{#1}%
\FPeval{\wide}{round(\iconWidth/20:3)}\psscalebox{\wide}{%
\psset{unit=1mm,dimen=middle,linestyle=solid,linewidth=\lineWidthStitch,fillstyle=none,linearc=0,framearc=0}%
\pscircle[linestyle=none,fillstyle=\fillStyle,fillcolor=\fillColor](0,0){10}%
\psarc(0,14){10}{225}{-45}%
\psarc(0,-13.5){10}{42}{137}%
\newcommand{\stitches}{%
\FPset{\rrr}{10}%
\multido{\nA=42+3.5}{27}{%
\FPeval{\xxx}{\fpeval{\rrr * cosd(\nA)}}%
\FPeval{\yyy}{\fpeval{\rrr * sind(\nA)}}%
\rput{\nA}(\xxx,\fpeval{\yyy-13.5}){\psarc[fillstyle=none](0,0){0.6}{45}{135}}%
\rput{\nA}(\xxx,\fpeval{\yyy-13.5}){\psdot(-0.44,0.4)}%
\rput{\nA}(\xxx,\fpeval{\yyy-13.5}){\psdot(0.44,0.4)}%
}}%
\psset{dotsize=0.3,dotstyle=o,fillstyle=solid,fillcolor=black,linewidth=0.1}%
\rput(0,0){\stitches}%
\rput(0,0.4){\psscalebox{-1 -1}{\stitches}}%
\pscircle[linestyle=\lineStyleCircle,linewidth=\lineWidthCircle,fillstyle=none](0,0){10}%
}}%
