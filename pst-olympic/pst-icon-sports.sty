\rput(-1.2,\fpeval{\nY+0.2}){\psline(0,0)(-0.3,\fpeval{\xpos+\del*(1 + \nY)})}%
\rput(2,\fpeval{\nY+0.2}){\psline(0,0)(0.3,\fpeval{\xpos + \del*(1 + \nY)})}%
\rput(-2,\fpeval{\nY+0.2}){\psline(0,0)(-0.3,\fpeval{\xpos + \del*(1 + \nY)})}%
