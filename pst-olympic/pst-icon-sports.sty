% \rput(20.7,\fpeval{-\nY*2}){\tiny{\nY,\fpeval{1.2 - 0.02(1 + \nY)}}}%
\rput(0.5,\nY){\psline(0,0)(0.1,\fpeval{\xneg - \del(1 + \nY)})}%
\rput(-0.5,\nY){\psline(0,0)(-0.1,\fpeval{\xneg - \del(1 + \nY)})}%
