\newcommand{\psLogoOlympicConstruction}[1][]{\setkeys{\kvf}{#1}%
\FPeval{\wide}{round(\iconWidth/44:3)}\psscalebox{\wide}{%
\psset{unit=1mm,dimen=middle,linestyle=none,linewidth=0,fillstyle=solid,linearc=0,framearc=0}%
\FPset{\radius}{6.5}%
\psset{linestyle=solid,linewidth=1,fillstyle=none}%
\pscircle[linecolor=blueOlympic](7,13.5){\radius}%
\pscircle[linecolor=blackOlympic](22,13.5){\radius}%
\pscircle[linecolor=redOlympic](37,13.5){\radius}%
\pscircle[linecolor=yellowOlympic](14.5,7){\radius}%
\pscircle[linecolor=greenOlympic](29.5,7){\radius}%
%
\psset{dotsize=0.3mm,fillstyle=solid,fillcolor=cyan,dotstyle=o}\tiny%
\sffamily%
\FPset{\sss}{0.3}%
\psdot(7,13.5)\rput[l](7,13){\psscalebox{\sss}{C1}}%
\psdot(22,13.5)\rput[l](22,13){\psscalebox{\sss}{C2}}%
\psdot(37,13.5)\rput[l](37,13){\psscalebox{\sss}{C3}}%
\psdot(14.5,7)\rput[l](14.5,6.5){\psscalebox{\sss}{C4}}%
\psdot(29.5,7)\rput[l](29.5,6.5){\psscalebox{\sss}{C5}}%
%
\psset{dotsize=0.5mm,fillcolor=red}%
\psdot(12.95887,12.799)\rput[r](12.8,12){\psscalebox{\sss}{P11}}%
\psdot(20.49062,6.665)\rput[r](20.1,6.3){\psscalebox{\sss}{P12}}%
\psdot(21.48346,6.519)\rput[l](21.6,6){\psscalebox{\sss}{P13}}%
\psdot(12.99062,13.835)\rput[r](12.6,14.4){\psscalebox{\sss}{P14}}%
%
\psdot(13.98047,12.977)\rput[l](14,12.2){\psscalebox{\sss}{P21}}%
\psdot(13.98346,13.981)\rput[l](14,14.6){\psscalebox{\sss}{P22}}%
\psdot(21.48047,7.523)\rput[l](21.6,8.1){\psscalebox{\sss}{P23}}%
\psdot(20.45887,7.701)\rput[r](20.2,8.4){\psscalebox{\sss}{P24}}%
\psset{linestyle=solid,linecolor=Green,linewidth=0.1,fillstyle=none}%
% C4--21--22
\FPeval{\angA}{\fpeval{180+\aTan{\fpeval{12.799-7}}{\fpeval{12.95887-14.5}}}}%
\FPeval{\angB}{\aTan{\fpeval{6.665-7}}{\fpeval{20.49062-14.5}}}%
\psarc(14.5,7){6}{\angA}{\angB}%
% C2--22--23
\FPeval{\angA}{\fpeval{180+\aTan{\fpeval{6.665-13.5}}{\fpeval{20.49062-22}}}}%
\FPeval{\angB}{\fpeval{180+\aTan{\fpeval{6.519-13.5}}{\fpeval{21.48346-22}}}}%
\psarc(22,13.5){7}{\angA}{\angB}%
% C4--23--24
\FPeval{\angA}{\aTan{\fpeval{6.519-7}}{\fpeval{21.48346-14.5}}}%
\FPeval{\angB}{\fpeval{180+\aTan{\fpeval{13.835-7}}{\fpeval{12.99062-14.5}}}}%
\psarcn(14.5,7){7}{\angA}{\angB}%
% C1--24--21
\FPeval{\angA}{\fpeval{0+\aTan{\fpeval{13.835-13.5}}{\fpeval{12.99062-7}}}}%
\FPeval{\angB}{\fpeval{0+\aTan{\fpeval{12.799-13.5}}{\fpeval{12.95887-7}}}}%
\psarcn(7,13.5){6}{\angA}{\angB}%
% C1--31--32
\FPeval{\angA}{\fpeval{0+\aTan{\fpeval{12.977-13.5}}{\fpeval{13.98047-7}}}}%
\FPeval{\angB}{\fpeval{0+\aTan{\fpeval{13.981-13.5}}{\fpeval{13.98346-7}}}}%
\psarc(7,13.5){7}{\angA}{\angB}%
% C4--32--33
\FPeval{\angA}{\fpeval{180+\aTan{\fpeval{13.981-7}}{\fpeval{13.98346-14.5}}}}%
\FPeval{\angB}{\fpeval{0+\aTan{\fpeval{7.523-7}}{\fpeval{21.48047-14.5}}}}%
\psarcn(14.5,7){7}{\angA}{\angB}%
% C2--33--34
\FPeval{\angA}{\fpeval{180+\aTan{\fpeval{7.523-13.5}}{\fpeval{21.48047-22}}}}%
\FPeval{\angB}{\fpeval{180+\aTan{\fpeval{7.701-13.5}}{\fpeval{20.45887-22}}}}%
\psarcn(22,13.5){6}{\angA}{\angB}%
% C4--34--31
\FPeval{\angA}{\fpeval{0+\aTan{\fpeval{7.701-7}}{\fpeval{20.45887-14.5}}}}%
\FPeval{\angB}{\fpeval{180+\aTan{\fpeval{12.977-7}}{\fpeval{13.98047-14.5}}}}%
\psarc(14.5,7){6}{\angA}{\angB}%
}}%
