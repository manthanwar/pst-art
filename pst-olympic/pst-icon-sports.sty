\rput(2,\fpeval{\nY-0.05}){\psline(0,0)(0.3,\fpeval{\xneg - \del*(1 + \nY)})}%
\rput(-2,\fpeval{\nY-0.05}){\psline(0,0)(-0.3,\fpeval{\xneg- \del*(1 + \nY)})}%
\fi%
}}%
