% \psarc(0,0){\radius}{-\ang}{\ang}%
% \rput{180}(0,0){\psarc(0,0){\radius}{-\ang}{\ang}}%
% \psline(\distX,\distY)(10;60)%
%
% \rput(0,0){\angB}%
% \psarc(0,0){\radius}{\angB}{\ang}%
% \psbezier(\radius;\fpeval{180-\angB})(-8,4)(8,4)(\radius;\angB)%
% \psarc(0,0){\radius}{\fpeval{180-\angB}}{\fpeval{180-\ang}}%
%
% \psset{fillstyle=none,linecolor=black}%
% \psarc(0,0){\radius}{-\angB}{\angB}%
% \psbezier(\radius;\angB)(3,4)(-3,4)(\radius;\fpeval{180-\angB})%
% \psarc(0,0){\radius}{\fpeval{180-\angB}}{\fpeval{180+\angB}}%
% \psbezier(\radius;\fpeval{180+\angB})(-3,-4)(3,-4)(\radius;-\angB)%
%
%-------------------------------------------------------------------------------
\newcommand{\psSportWaterPoloBall}[1][]{\setkeys{\kvf}{#1}%
\FPeval{\wide}{round(\iconWidth/20:3)}\psscalebox{\wide}{%
\psset{unit=1mm,dimen=middle,linearc=0,framearc=0}%
\FPset{\pushAaX}{10.68}%
\pscircle[linestyle=none,fillstyle=\fillStyle,fillcolor=\fillColor](0,0){10}%
%
\FPset{\radius}{8.5}%
\FPset{\distX}{6}%
\FPeval{\ang}{\aSin{\distX}{\radius}}%
\FPeval{\distY}{\cosd{0}{\radius}{\ang}}%
\FPset{\distYB}{2}%
\FPeval{\angB}{\aSin{\distYB}{\radius}}%
%
\newcommand{\arcA}{\pscustom{\psarc(0,0){10}{-60}{60}%
\psline(10;60){\distX,\distY}\psarcn(0,0){\radius}{\ang}{-\ang}\closepath}}%
%
\newcommand{\headA}{\pscustom{\psarc(0,0){10}{60}{75}\psline(10;75)(1.5,6)(\distX,\distY)\closepath}}%
%
\newcommand{\headC}{\pscustom{%
\psarc(0,0){10}{75}{105}\psline(10;105)(-1.5,6)(1.5,6)(10;75)\closepath}}%
%
\newcommand{\centerA}{\pscustom{\psarc(0,0){\radius}{\angB}{\ang}%
\psarc(0,0){\radius}{\fpeval{180-\ang}}{\fpeval{180-\angB}}%(\radius;\fpeval{180-\angB})
\psbezier(-3,4)(3,4)(\radius;\angB)\closepath}}%
%
\newcommand{\centerC}{\pscustom{%
\psarc(0,0){\radius}{-\angB}{\angB}%(\radius;\angB)
\psbezier(3,4)(-3,4)(\radius;\fpeval{180-\angB})%
\psarc(0,0){\radius}{\fpeval{180-\angB}}{\fpeval{180+\angB}}%(\radius;\fpeval{180+\angB})
\psbezier(-3,-4)(3,-4)(\radius;-\angB)\closepath}}%
%
\psset{fillstyle=\fillStyle,fillcolor=\fillColorA,linestyle=\lineStyle,linecolor=\lineColor,linewidth=\lineWidth}%
\rput(0,0){\arcA}%
\rput{180}(0,0){\arcA}%
%
\psset{fillcolor=\fillColorB}%
\rput(0,0){\headA}%
\rput(0,0){\psscalebox{-1 1}{\headA}}%
\rput{180}(0,0){\headA}%
\rput{180}(0,0){\psscalebox{-1 1}{\headA}}%
%
\psset{fillcolor=\fillColorC}%
\rput(0,0){\headC}%
\rput{180}(0,0){\headC}%
%
\psset{fillcolor=\fillColorD}%
\rput(0,0){\centerA}%
\rput{180}(0,0){\centerA}%
%
\psset{fillcolor=\fillColor}%
\rput(0,0){\centerC}%
%
\pscircle[fillstyle=none,linestyle=\lineStyleCircle,linecolor=\lineColorCircle,linewidth=\lineWidthCircle](0,0){10}%
}}%
