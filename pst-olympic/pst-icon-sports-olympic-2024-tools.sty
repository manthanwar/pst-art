% Archery Arrow With Bow
%-------------------------------------------------------------------------------
\newcommand{\psOlympicXxivArrowBow}[1][]{\setkeys{\kvf}{#1}%
\FPeval{\wide}{round(\iconWidth/20:3)}\psscalebox{\wide}{%
\psset{unit=1mm,dimen=middle,linearc=0,framearc=0}%
