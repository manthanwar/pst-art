\newcommand{\psOlympicXxivBeachVolleyballBall}[1][]{\setkeys{\kvf}{#1}%
\FPeval{\wide}{round(\iconWidth/20:3)}\psscalebox{\wide}{%
\psset{unit=1mm,dimen=middle,linearc=0,framearc=0}%
\pscircle[linestyle=none,fillstyle=\fillStyleBall,fillcolor=\fillColorBall](0,0){10}%
\newcommand{\stripA}{\pscustom{\psbezier(0,0)(3,5)(10;30)(10;30)\psarc(0,0){10}{30}{54}\psbezier(10;54)(-1,7)(-3.31,0.56)(-3.31,0.56)(-1.95,0)(0,0)}}%
\newcommand{\stripB}{\pscustom{\psbezier(-3.31,0.56)(-1,7)(10;54)(10;54)\psarc(0,0){10}{56}{80}\psbezier(10;80)(-5,8)(-6.6,2.52)(-6.6,2.52)(-5.17,1.18)(-3.31,0.56)}}%
