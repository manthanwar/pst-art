% Artistic Swimming Costume Drawn Width = 20, Height = 42
%-------------------------------------------------------------------------------
\newcommand{\psOlympicXxivSwimmingCostume}[1][]{\setkeys{\kvf}{#1}%
\FPeval{\wide}{round(\iconWidth/20:3)}\psscalebox{\wide}{%
\psset{unit=1mm,dimen=middle,cornersize=absolute,linearc=0,framearc=0,linejoin=1}%
\psset{fillstyle=\fillStyle,fillcolor=\fillColor,linestyle=\lineStyle,linecolor=\lineColor,linewidth=\lineWidth}%
% Top
\newcommand{\costumeTop}{%
\pscustom{\psbezier(9,12)(5,26)(10,28)(10,34)%(10,34)
\psbezier(9,41)(5,42)(5,42)%
\psline(5,42)(4,41)%(4,41)
\psbezier(4,41)(7,40)(8,35)%\psbezier(8,35)
(4,35)(4,32)(0,32)%\psbezier(0,32)
(-4,32)(-4,35)(-8,35)%\psbezier(-8,35)
(-7,40)(-4,41)(-4,41)%
\psline(-4,41)(-5,42)%(-5,42)
\psbezier(-5,42)(-9,41)(-10,34)%\psbezier(-10,34)
(-10,23)(6,21)(9,12)\closepath}}%
% Bottom
\newcommand{\costumeBottom}{\pscustom{\psbezier(1,0)(1,3)(6,8)(10,10)%
(9,16)(-8,26)(-8,26)%\psbezier(-8,25)
(-6,24)(-6,19)(-10,10)%\psbezier(-10,10)
(-6,8)(-1,3)(-1,0)\closepath}}%
\rput(0,-21){\costumeTop}%
\rput(0,-21){\costumeBottom}%
}}%
