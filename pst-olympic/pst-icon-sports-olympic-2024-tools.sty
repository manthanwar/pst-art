%
\psset{linestyle=\lineStyleBallLines,linecolor=\lineColorBallLines,linewidth=\lineWidthBallLines,fillstyle=\fillStyleStrip}%
\psset{fillcolor=\fillColorStripAa}\rput(0,0){\stripA}%
\psset{fillcolor=\fillColorStripBa}\rput(0,0){\stripB}%
\psset{fillcolor=\fillColorStripCa}\rput(0,0){\stripC}%
\rput{120}(0,0){%
\psset{fillcolor=\fillColorStripAb}\rput(0,0){\stripA}%
\psset{fillcolor=\fillColorStripBb}\rput(0,0){\stripB}%
\psset{fillcolor=\fillColorStripCb}\rput(0,0){\stripC}}%
\rput{240}(0,0){%
\psset{fillcolor=\fillColorStripAc}\rput(0,0){\stripA}%
\psset{fillcolor=\fillColorStripBc}\rput(0,0){\stripB}%
\psset{fillcolor=\fillColorStripCc}\rput(0,0){\stripC}}%
\pscircle[fillstyle=none,linestyle=\lineStyleBall,linecolor=\lineColorBall,linewidth=\lineWidthBall](0,0){10}%
}}%
