% Cross Lines
%-------------------------------------------------------------------------------
\newcommand{\psOlympicXxivCrossLines}[1][]{\setkeys{\kvf}{#1}%
\FPeval{\wide}{round(\iconWidth/20:3)}\psscalebox{\wide}{%
\psset{unit=1mm,dimen=middle,cornersize=absolute,linearc=0,framearc=0,linejoin=1,fillstyle=none}%
\psset{linestyle=\lineStyle,linecolor=\lineColor,linewidth=\lineWidth}%
\psline(-8,-8)(8,8)\psline(8,-8)(-8,8)%
}}
%-------------------------------------------------------------------------------
\newcommand{\psOlympicXxivCrossLinesA}[1]{%
\FPeval{\wide}{round(#1/20:3)}\psscalebox{\wide}{%
\psset{unit=1mm,dimen=middle,cornersize=absolute,linearc=0,framearc=0,linejoin=1,fillstyle=none}%
% \psset{linestyle=\lineStyle,linecolor=\lineColor,linewidth=\lineWidth}%
\psline(-8,-8)(8,8)\psline(8,-8)(-8,8)%
}}
