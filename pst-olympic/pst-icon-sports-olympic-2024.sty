% region 05 Badminton
\newcommand{\psOlympicXxivBadmintonShuttleA}[1][20]{%
\FPeval{\wide}{round(#1/30:3)}\psscalebox{\wide}{%
% Cork Head
\pscustom{\psbezier(5,4)(-2,4)(-2,-4)(5,-4)\psline(5,-4)(5,4)\closepath}%
% Cork Soft
\psframe(6,-4)(8,4)%
% Feather Short A
\newcommand{\featherShortA}{\pspolygon(9,3)(13,4.1)(13,6)(9,4.4)}%
% Feather Short B
\newcommand{\featherShortB}{\pspolygon(9,0.5)(13,0.5)(13,3)(9,2)}%
% Feather Long A
\newcommand{\featherLongA}{\pscustom{%
\psbezier(27,8)(28,8)(30,12)(28,12)\psline(28,12)(14,6.5)(14,4.4)(27,8)}}%
% Feather Long B
\newcommand{\featherLongB}{\pscustom{%
\psline(14,0.5)(28,0.5)%(28,0.5)
\psbezier(28,0.5)(30,3)(30,4)%\psbezier(30,4)
(30,5)(29,7)(28,7)%
\psline(28,7)(14,3.3)(14,0.5)}}%
%
\rput(0,0){\featherShortA}%
\rput(0,0){\featherShortB}%
\rput(0,0){\featherLongA}%
\rput(0,0){\featherLongB}%
\rput(0,0){\psscalebox{1 -1}{\featherShortA}}%
\rput(0,0){\psscalebox{1 -1}{\featherShortB}}%
\rput(0,0){\psscalebox{1 -1}{\featherLongA}}%
\rput(0,0){\psscalebox{1 -1}{\featherLongB}}%
}}%
%-------------------------------------------------------------------------------
