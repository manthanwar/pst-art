% region 00 Olympic Logo
\newcommand{\psOlympicXxivLogo}[1][]{\setkeys{\kvf}{#1}%
\FPeval{\wide}{round(\iconWidth/44:3)}\psscalebox{\wide}{%
\psset{unit=1mm,dimen=middle,linestyle=none,linewidth=0,fillstyle=solid,linearc=0,framearc=0}%
\newcommand{\ringYellowA}[1]{%
\pscustom[fillcolor=##1]{%
\psarc(14.5,7){6}{104.8828}{-3.2007}%
\psarc(22,13.5){7}{257.5472}{265.7683}%
\psarcn(14.5,7){7}{-3.9401}{102.4528}%
\psarcn(7,13.5){6}{3.2007}{-6.7094}%
}}%
\newcommand{\ringYellowB}[1]{%
\pscustom[fillcolor=##1]{%
\psarc(7,13.5){7}{-4.2848}{3.9401}%
\psarcn(14.5,7){7}{94.2317}{4.2848}%
\psarcn(22,13.5){6}{265.0322}{255.1172}%
\psarc(14.5,7){6}{6.7094}{94.9678}%
}}%
{%
\FPset{\radius}{6.5}%
\psset{linestyle=solid,linewidth=1,fillstyle=none}%
\pscircle[linecolor=blueOlympic](7,13.5){\radius}%
\pscircle[linecolor=redOlympic](37,13.5){\radius}%
}%
%
\ringYellowA{yellowOlympic}%
\ringYellowB{yellowOlympic}%
\rput(36.5,20.5){\psscalebox{-1 -1}{\ringYellowA{blackOlympic}}}%
\rput(36.5,20.5){\psscalebox{-1 -1}{\ringYellowB{blackOlympic}}}%
\rput(15,0){\ringYellowA{greenOlympic}}%
\rput(15,0){\ringYellowB{greenOlympic}}%
%
}}%
% endregion Olympic Logo

