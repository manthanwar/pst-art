% region \psLed -> Blank 5 x 7 dot matrix LED -> width: 16. height: 22
\newcommand{\psLedBack}[1][]{\psset{dimen=middle,linestyle=none,fillstyle=solid,fillcolor=\ledColorBacklit}\psset{#1}%
% \psframe(0,0)(16,22)%
\psframe(0,0)(20,26)%
}%
%-------------------------------------------------------------------------------
\newcommand{\psLedBlank}[1][]{\psset{linestyle=none,fillstyle=solid,fillcolor=\ledColorOff}\psset{#1}%
\multirput(0,0)(0,3){7}{\multirput(2,2)(3,0){5}{\pscircle(0,0){1}}}%
% \multido{\iY=0+1,\iB=2+3}{7}{\multido{\iX=0+1,\iA=2+3}{5}{\pscircle(\iA,\iB){1}}}%
}%
%-------------------------------------------------------------------------------
% endregion \psLed
%-------------------------------------------------------------------------------
% region \ledLit
% \newcommand{\ledLit}[3][red]{%
\NewDocumentCommand{\ledLit}{O{} D(){1,1}}{%\psset{#1}%
\StrBefore{#2}{,}[\litX]\StrBehind{#2}{,}[\litY]%
\psset{linestyle=none,fillstyle=solid,fillcolor=\ledColorOff}\psset{#1}%
\multido{\iY=0+1,\iB=2+3}{7}{\multido{\iX=0+1,\iA=2+3}{5}{%
\ifnum\iX=\litX\relax\ifnum\iY=\litY\relax%
\pscircle[fillcolor=\ledColorOn](\iA,\iB){1}\else\pscircle(\iA,\iB){1}\fi%
\else\pscircle(\iA,\iB){1}\fi%
}}}%
% endregion \ledLit
%-------------------------------------------------------------------------------
% region \ledOn
\NewDocumentCommand{\ledOn}{O{0} D(){1,1}}{%
\ifnum#1=1\relax\psset{fillcolor=\ledColorOn}%
\else\psset{fillcolor=\ledColorOff}\fi%
\StrBefore{#2}{,}[\litX]\StrBehind{#2}{,}[\litY]%
% \pscircle(\fpeval{2 + 3*\litX},\fpeval{2 + 3*\litY}){1}%
\pscircle(\fpeval{4 + 3*\litX},\fpeval{4 + 3*\litY}){1}%
}%
% endregion \ledOn
%-------------------------------------------------------------------------------
% region \psLedOff
\newcommand{\psLedOff}[1][]{\rput(0,0){\psLedBack}%
\ledOn[0](0,6) \ledOn[0](1,6) \ledOn[0](2,6) \ledOn[0](3,6) \ledOn[0](4,6)%
\ledOn[0](0,5) \ledOn[0](1,5) \ledOn[0](2,5) \ledOn[0](3,5) \ledOn[0](4,5)%
\ledOn[0](0,4) \ledOn[0](1,4) \ledOn[0](2,4) \ledOn[0](3,4) \ledOn[0](4,4)%
